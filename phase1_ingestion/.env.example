# ==============================================
# AI-Powered Review Discovery Engine — Phase 1
# Environment Variables
# ==============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── PostgreSQL ──────────────────────────────
POSTGRES_USER=review_engine
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=reviews_db

# ── n8n ─────────────────────────────────────
N8N_HOST=localhost
N8N_ENCRYPTION_KEY=your_32_char_encryption_key_here

# ── Reddit (NO API KEY NEEDED) ──────────────────────────────
# We use Reddit's free public JSON endpoints.
# No sign-up required. Just leave these as-is.
# REDDIT_API_KEY=not_required

# ── Twitter / X (EXCLUDED — Paid API) ────────────────────────
# Twitter API costs $100/month. Not used in v1.0.
# TWITTER_BEARER_TOKEN=not_used

# ── YouTube Data API v3 (FREE) ────────────────────────────────
# Get your free key in 2 minutes:
#   1. Go to https://console.cloud.google.com/
#   2. Create new project (e.g., SpotifyReviewEngine)
#   3. Search for 'YouTube Data API v3' and ENABLE it
#   4. Go to Credentials → + CREATE CREDENTIALS → API Key
#   5. Copy the key below
# Free quota: 10,000 units/day (our scraper uses ~600 units/day)
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── App Store ────────────────────────────────
# Spotify App ID on App Store
APPSTORE_APP_ID=324684580
APPSTORE_COUNTRY=us

# ── Play Store ───────────────────────────────
# Spotify Package Name on Play Store
PLAYSTORE_APP_ID=com.spotify.music
PLAYSTORE_COUNTRY=us
PLAYSTORE_LANGUAGE=en

# ── Application Settings ─────────────────────
LOG_LEVEL=INFO
# Spotify Community Forum base URL
SPOTIFY_FORUM_BASE_URL=https://community.spotify.com
